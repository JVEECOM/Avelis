    "rich_text_welcome": {
      "type": "rich-text",
      "blocks": {
        "welcome_richtext": {
          "type": "richtext",
          "settings": {
            "content": "<p>For years, we’ve had the privilege of building this boutique in the heart of New York — a space where timeless style meets the effortless energy of the city.</p><p>Every piece you’ll find here has been carefully selected with intention: to feel refined, distinctive, and quietly confident. This boutique has never been about trends alone, but about creating a wardrobe that feels personal, enduring, and uniquely yours.</p><p>New York is constantly evolving — and so are we. As the rhythm of the city shifts, we take a moment to reintroduce what this space stands for: thoughtful fashion, elevated essentials, and pieces designed to be worn and loved for years to come.</p><p>This boutique is, and always will be, a reflection of our passion for craftsmanship, detail, and understated elegance.</p><p>We are truly grateful to everyone who has been part of this journey — and we look forward to welcoming you (back) into our world.</p><p>— the Avelis New York team</p>"
          }
        }
      },
      "block_order": [
        "welcome_richtext"
      ],
      "settings": {
        "full_width": true,
        "content_width": "medium",
        "text_position": "center",
        "background": "#D4A5A5",
        "text_color": "#ffffff"
      }
